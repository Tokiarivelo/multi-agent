# =============================================================================
# MULTI-AGENT PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and configure for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/multi_agent?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=multi_agent

# =============================================================================
# NATS CONFIGURATION (Event Streaming)
# =============================================================================
NATS_URL=nats://localhost:4222
NATS_CLUSTER_ID=multi-agent-cluster

# =============================================================================
# VECTOR DATABASE CONFIGURATION (Qdrant)
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET=your-jwt-secret-key-here-min-32-chars
JWT_EXPIRES_IN=1d

# =============================================================================
# API KEY ENCRYPTION
# =============================================================================
# 32-byte hex string for AES-256 encryption
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here-for-aes256-encryption

# =============================================================================
# SERVICE PORTS
# =============================================================================
GATEWAY_PORT=3000
FRONTEND_PORT=3001
AGENT_PORT=3002
ORCHESTRATION_PORT=3003
EXECUTION_PORT=3004
MODEL_PORT=3005
TOOL_PORT=3030
TOOL_SERVICE_URL=http://localhost:3030
EMAIL_MCP_PORT=3012
EMAIL_MCP_URL=http://localhost:3012
CALENDAR_MCP_PORT=3013
CALENDAR_MCP_URL=http://localhost:3013
VECTOR_PORT=3007

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGIN=http://localhost:3001

# =============================================================================
# LLM PROVIDER API KEYS (Optional - can be added via Model Service API)
# =============================================================================
# These are fallback keys. Users can add their own via the Model Service
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
NODE_ENV=development

# =============================================================================
# DOCKER & KUBERNETES
# =============================================================================
REGISTRY=docker.io
IMAGE_TAG=latest
NAMESPACE=default

# =============================================================================
# MONITORING (Optional)
# =============================================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3010

# =============================================================================
# FILE SYSTEM (MinIO)
# =============================================================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=multi-agent-files
FILE_PORT=3008


# =============================================================================
# OAuth
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

# =============================================================================
# Gmail API (for Email MCP Service and Orchestration Service)
# =============================================================================
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gmail-pubsub-credentials.json

# Optionnel : Si vous n'utilisez pas GOOGLE_APPLICATION_CREDENTIALS
# PUBSUB_CREDENTIALS_PATH=/path/to/your/gmail-pubsub-credentials.json

# =============================================================================
# API KEY
# =============================================================================
INTERNAL_SECRET=your-internal-api-secret-key-here-min-32-chars

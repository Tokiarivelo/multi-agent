GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# OR use file path:
# GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app.pem
GITHUB_APP_INSTALLATION_ID=78910
GITHUB_MCP_PORT=3010
NODE_ENV=development

# GitHub OAuth App credentials (for the /github/authorize UI flow)
# Create at: Settings → Developer settings → OAuth Apps → New OAuth App
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3001/api/github/callback

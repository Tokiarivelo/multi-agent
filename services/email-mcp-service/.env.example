# Server Configuration
EMAIL_MCP_PORT=3012
NODE_ENV=development

# SMTP Configuration (Google Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# IMAP Configuration (Gmail fetch — defaults fall back to SMTP_USER / SMTP_PASS)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
# IMAP_USER=your-email@gmail.com   # optional: defaults to SMTP_USER
# IMAP_PASS=your-app-password      # optional: defaults to SMTP_PASS

# Gmail API OAuth2 (for gmail_watch tool)
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret

# Google Cloud Pub/Sub (for gmail_pull_notifications)
# This env var is the standard Google Cloud method for Application Default Credentials
# Point it to the absolute path of your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gmail-pubsub-credentials.json

# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/multi_agent

# CORS Configuration
CORS_ORIGIN=*

# External Services
AGENT_SERVICE_URL=http://localhost:3002
TOOL_SERVICE_URL=http://localhost:3030
EXECUTION_SERVICE_URL=http://localhost:3004

# Execution Settings
MAX_RETRY_ATTEMPTS=3
EXECUTION_TIMEOUT=300000

# Gmail Push Notifications (Auto-polling)
GMAIL_POLLING_ENABLED=true
GMAIL_PUBSUB_PROJECT_ID=your-project-id
GMAIL_PUBSUB_SUBSCRIPTION=gmail-notifications-sub
EMAIL_MCP_URL=http://localhost:3012

# Google Cloud Credentials (for Gmail Pub/Sub polling)
# This env var is the standard Google Cloud method for Application Default Credentials
# Point it to the absolute path of your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gmail-pubsub-credentials.json

        "id": "start-node",
        "type": "START",
        "customName": "Start",
        "config": {},
        "position": {
          "x": 100,
          "y": 0
        }
      },
      {
        "id": "cuisine-input",
        "type": "PROMPT",
        "customName": "Format Cuisine Request",
        "config": {
          "template": "You are a European cuisine specialist. The user asks: {{input.query}}\n\nProvide detailed guidance on European cooking techniques, recipes, ingredients, and culinary traditions."
        },
        "position": {
          "x": 100,
          "y": 200
        }
      },
      {
        "id": "cuisine-agent",
        "type": "AGENT",
        "config": {
          "prompt": "{{input.template}}",
          "agentId": "05ece5fc-0bc2-4611-b08d-1588dd026fd8"
        },
        "position": {
          "x": 100,
          "y": 400
        },
        "customName": "European Cuisine Expert"
      },
      {
        "id": "refine-response",
        "type": "AGENT",
        "customName": "Refine Culinary Advice",

        "target": "cuisine-input"
      },
      {
        "id": "edge-input-to-agent",
        "source": "cuisine-input",
        "target": "cuisine-agent"
      },
      {
        "id": "edge-agent-to-refine",
        "source": "cuisine-agent",
        "target": "refine-response"
      },
      {
        "id": "4a49fcf2-5243-4b53-82bb-f515986d1cda",
